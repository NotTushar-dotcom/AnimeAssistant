# =============================================================================
# AARA - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your API keys
# Only add keys for services you want to use
# Aara will automatically fall back to free alternatives
# =============================================================================

# =============================================================================
# PRESET CONFIGURATION
# =============================================================================
# Options: free, balanced, premium, auto
# - free: Uses only free services (Ollama, Edge TTS, DuckDuckGo)
# - balanced: Groq cloud LLM + free TTS (best free quality)
# - premium: Claude + ElevenLabs (best quality, costs money)
# - auto: Automatically detect based on available API keys
AARA_PRESET=auto

# =============================================================================
# LLM PROVIDERS (Brain)
# =============================================================================

# PREMIUM: Anthropic Claude ($15/1M tokens) - Best quality
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# FREE: Groq Cloud (Llama 3.1 70B) - Fast & high quality
# Get at: https://console.groq.com
GROQ_API_KEY=

# FREE: Google Gemini (15 req/min free tier)
# Get at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# FREE: OpenRouter (aggregates many models)
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# FREE: Ollama (local) - No key needed, just install
# Install from: https://ollama.ai
# Then run: ollama pull llama3.2:8b
OLLAMA_MODEL=llama3.2:8b
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# TEXT-TO-SPEECH (TTS)
# =============================================================================

# PREMIUM: ElevenLabs ($5/mo starter) - Best voices
# Get at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_ENGLISH=
ELEVENLABS_VOICE_ID_HINDI=

# FREE: Edge TTS - No key needed (Microsoft neural voices)
# Voices used: en-US-AnaNeural, hi-IN-SwaraNeural
EDGE_TTS_VOICE_ENGLISH=en-US-AnaNeural
EDGE_TTS_VOICE_HINDI=hi-IN-SwaraNeural

# =============================================================================
# SPEECH-TO-TEXT (STT)
# =============================================================================

# Whisper runs locally - no API key needed
# Options: large-v3 (best, needs GPU), base (good, CPU ok), tiny (fast)
WHISPER_MODEL=base

# =============================================================================
# WAKE WORD DETECTION
# =============================================================================

# PREMIUM: Picovoice Porcupine (free tier: 3 words)
# Get at: https://picovoice.ai
PICOVOICE_ACCESS_KEY=

# FREE: Uses Ctrl+Space hotkey instead (no key needed)
ACTIVATION_HOTKEY=ctrl+space

# =============================================================================
# WEB SEARCH
# =============================================================================

# PREMIUM: Serper ($50/5000 searches) - Google results
# Get at: https://serper.dev
SERPER_API_KEY=

# FREE: DuckDuckGo - No key needed (unlimited)

# =============================================================================
# WEATHER
# =============================================================================

# OPTIONAL: OpenWeatherMap (free tier available)
# Get at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# FREE: Open-Meteo - No key needed, used by default

# =============================================================================
# APP SETTINGS
# =============================================================================

# User's name (Aara will use this)
USER_NAME=

# Default city for weather
DEFAULT_CITY=Delhi

# Theme: dark, light
THEME=dark

# Window position on startup (bottom-right by default)
WINDOW_POSITION=bottom-right

# Start minimized to tray
START_MINIMIZED=false

# =============================================================================
# DEVELOPER SETTINGS
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode (verbose logging)
DEBUG_MODE=false
