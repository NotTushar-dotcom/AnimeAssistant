# =============================================================================
# AARA CONFIGURATION
# =============================================================================
# Choose your preset: "free", "balanced", or "premium"
AARA_PRESET=free

# =============================================================================
# PREMIUM API KEYS (Only needed if using premium services)
# =============================================================================

# LLM - Claude (Premium)
ANTHROPIC_API_KEY=your_claude_api_key_here

# LLM - OpenAI (Premium)
OPENAI_API_KEY=your_openai_api_key_here

# TTS - ElevenLabs (Premium)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID_ENGLISH=your_voice_id_here
ELEVENLABS_VOICE_ID_HINDI=your_voice_id_here

# Wake Word - Picovoice (Free tier available)
PICOVOICE_ACCESS_KEY=your_picovoice_key_here

# Search - Serper (Premium)
SERPER_API_KEY=your_serper_api_key_here

# Search - Tavily (Premium)
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# FREE TIER API KEYS (Optional - improves free experience)
# =============================================================================

# LLM - Groq (FREE - 30 requests/min)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM - Google Gemini (FREE - 15 requests/min)
# Get key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# LLM - OpenRouter (Some FREE models)
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Weather - OpenWeatherMap (FREE tier available)
# Get key at: https://openweathermap.org/api
# NOTE: Open-Meteo needs NO key - it's the default!
OPENWEATHERMAP_API_KEY=your_weather_api_key_here

# =============================================================================
# NO API KEY NEEDED (Completely Free!)
# =============================================================================
# These services work without any API keys:
#
# - Ollama (Local LLM)     → Install from: https://ollama.ai
# - Whisper Local (STT)    → Included in requirements
# - Edge TTS (Voice)       → Microsoft's free TTS API
# - Open-Meteo (Weather)   → Free weather API
# - DuckDuckGo (Search)    → Free search API
# - Vosk (STT alternative) → Lightweight offline STT

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
DEBUG_MODE=false
LOG_LEVEL=INFO
